{
  "scopeName": "source.sss-secrets",
  "name": "SSS Secrets",
  "patterns": [
    {
      "name": "comment.line.number-sign.sss-secrets",
      "match": "^\\s*#.*$"
    },
    {
      "name": "meta.key-value.multiline.sss-secrets",
      "begin": "^\\s*(?:\"([^\"]+)\"|'([^']+)'|([^:\\s][^:]*?))\\s*(:)\\s*(\\|)\\s*$",
      "beginCaptures": {
        "1": { "name": "entity.name.tag.sss-secrets.key" },
        "2": { "name": "entity.name.tag.sss-secrets.key" },
        "3": { "name": "entity.name.tag.sss-secrets.key" },
        "4": { "name": "punctuation.separator.key-value.sss-secrets" },
        "5": { "name": "keyword.operator.multiline.sss-secrets" }
      },
      "end": "^(?!\\s+)",
      "patterns": [
        {
          "name": "string.unquoted.multiline.sss-secrets.value",
          "match": "^\\s+.*$"
        }
      ]
    },
    {
      "name": "meta.key-value.single-line.sss-secrets",
      "match": "^\\s*(?:\"([^\"]+)\"|'([^']+)'|([^:\\s][^:]*?))\\s*(:)\\s*(?:\"([^\"]*)\"|'([^']*)'|(.*))?\\s*$",
      "captures": {
        "1": { "name": "entity.name.tag.sss-secrets.key" },
        "2": { "name": "entity.name.tag.sss-secrets.key" },
        "3": { "name": "entity.name.tag.sss-secrets.key" },
        "4": { "name": "punctuation.separator.key-value.sss-secrets" },
        "5": { "name": "string.quoted.double.sss-secrets.value" },
        "6": { "name": "string.quoted.single.sss-secrets.value" },
        "7": { "name": "string.unquoted.sss-secrets.value" }
      }
    }
  ]
}
