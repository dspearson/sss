#!/bin/bash
# SSS post-checkout hook
# Automatically processes encrypted files after checkout/clone
# Priority: render (if enabled) > open (if enabled) > skip

# Check if sss is available
if ! command -v sss &> /dev/null; then
    exit 0
fi

# Check if we're in an sss repository
if ! sss status &> /dev/null; then
    exit 0
fi

# Try to render project files (requires auto-render permission)
sss render --project 2>&1 || true

exit 0
